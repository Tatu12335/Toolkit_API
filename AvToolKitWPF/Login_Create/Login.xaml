<mah:MetroWindow x:Class="AvToolKitWPF.Login_Create.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvToolKitWPF.Login_Create"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock Text="Username : "/>

            <TextBox Margin="10" 
                      Name="UsernameTextbox" />

            <TextBlock Text="Password : "/>
            <PasswordBox Margin="10" 
                         x:Name="PasswordBox" />
            <Button Margin="10"
                    Content="Login" Width="96" 
                    Click="Button_Click"/>
            <TextBlock  FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"><Hyperlink Click="Hyperlink_Click_1"><Run Text="create account"/></Hyperlink></TextBlock>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
