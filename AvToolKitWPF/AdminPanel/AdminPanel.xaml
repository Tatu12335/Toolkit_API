<Window x:Class="AvToolKitWPF.AdminPanel.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvToolKitWPF.AdminPanel"
        mc:Ignorable="d"
        Title="AdminPanel" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock Text="Admin Panel" FontSize="24" FontWeight="Bold" Margin="10"/>
            <Button Content="Manage Users" Width="150" Margin="10" Click="ButtonManageUsers_Click"/>
            <Button Content="View Logs" Width="150" Margin="10" Click="ButtonViewLogs_Click"/>
            <Button Content="Settings" Width="150" Margin="10" Click="ButtonSettings_Click"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10">
            <Button Content="Logout" Width="80" Click="ButtonLogout_Click"/>
        </StackPanel>
        <StackPanel>
        </StackPanel>
    </Grid>
</Window>
