<Window x:Class="AvToolKitWPF.AdminPanel.ManageUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvToolKitWPF.AdminPanel"
        mc:Ignorable="d"
        Title="ManageUsersWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock Text="Manage Users" FontSize="24" FontWeight="Bold" Margin="10"/>
            <Button Content="Add User" Width="100" Margin="10"/>
            <Button Content="Edit User" Width="100" Margin="10"/>
            <Button Content="Delete User" Width="100" Margin="10"/>
            
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBox Width="200" Margin="0,0,10,0" Text="Search by username"/>
                <Button Content="Search" Width="80"/>
                <Button Content="Refresh" Width="100" Margin="10"/>
            </StackPanel>
            <StackPanel>
                <CheckBox Content="Show Admins Only" Margin="10"/>
                <CheckBox Content="Show Active Users Only" Margin="10"/>
                <ListBox Margin="10" Name="UsersListBox">
                    <ListBoxItem Content="User1 - Admin"/>
                    <ListBoxItem Content="User2 - User"/>
                    <ListBoxItem Content="User3 - User"/>
                </ListBox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
